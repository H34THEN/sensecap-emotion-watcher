{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/circe/emotion-entry.schema.json",
  "title": "Circe EmotionEntry",
  "description": "Planning schema for CIRCE emotional reflection entries. Not yet enforced in firmware.",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "created_at",
    "device_id",
    "completion_status",
    "flow_path",
    "emotion_skipped",
    "color_hex",
    "color_source",
    "intensity",
    "body_areas",
    "body_sensations",
    "context_tags",
    "summary_text",
    "training_ok",
    "private_locked"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "id": { "type": "string", "format": "uuid" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "device_id": { "type": "string", "minLength": 1 },
    "completion_status": { "type": "string", "enum": ["complete", "partial"] },
    "flow_path": { "type": "string", "enum": ["standard", "body_first"] },
    "entry_mode": {
      "type": "string",
      "enum": ["body_only", "quick", "regulation"]
    },
    "regulation_type": {
      "type": "string",
      "enum": ["breathing", "body_anchor", "grounding_54321", "sensory_reset", "bilateral_tap"]
    },
    "rounds_completed": { "type": "integer", "minimum": 0 },
    "steps_completed": { "type": "integer", "minimum": 0 },
    "duration_seconds": { "type": "integer", "minimum": 0 },
    "session_completed": { "type": "boolean" },
    "emotion": { "type": ["string", "null"] },
    "emotion_label": { "type": "string" },
    "emotion_family": { "type": "string" },
    "emotional_tone": { "type": "string" },
    "emotion_skipped": { "type": "boolean" },
    "color_hex": { "type": ["string", "null"], "pattern": "^#[0-9A-Fa-f]{6}$" },
    "color_label": { "type": "string" },
    "color_source": {
      "type": "string",
      "enum": ["picker", "hex", "favorite", "default", "touch_picker", "preset", "skipped", "unknown"]
    },
    "color_skipped": { "type": "boolean" },
    "color_hue": { "type": "number", "minimum": 0, "maximum": 360 },
    "color_saturation": { "type": "number", "minimum": 0, "maximum": 1 },
    "color_value": { "type": "number", "minimum": 0, "maximum": 1 },
    "color_family": {
      "type": "string",
      "enum": ["red", "orange", "yellow", "green", "cyan", "blue", "purple", "pink", "gray", "unknown"]
    },
    "color_temperature": {
      "type": "string",
      "enum": ["warm", "cool", "neutral", "unknown"]
    },
    "color_brightness_label": {
      "type": "string",
      "enum": ["dark", "dim", "balanced", "bright"]
    },
    "color_saturation_label": {
      "type": "string",
      "enum": ["muted", "soft", "vivid"]
    },
    "photo_attached": { "type": "boolean" },
    "photo_id": { "type": "string" },
    "photo_path": { "type": "string" },
    "photo_created_at": { "type": "string" },
    "photo_consent": { "type": "boolean" },
    "photo_training_ok": { "type": "boolean" },
    "intensity": { "type": "integer", "minimum": 1, "maximum": 10 },
    "body_areas": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "head", "eyes", "jaw", "throat", "chest", "stomach",
          "shoulders", "back", "arms", "hands", "hips", "legs",
          "feet", "skin", "whole_body"
        ]
      }
    },
    "body_sensations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "tight", "pressure", "heavy", "shaky", "buzzing", "tingling",
          "hot", "cold", "numb", "floaty", "nauseous", "racing_heart",
          "shallow_breathing", "skin_crawling", "overstimulated",
          "shutdown_feeling", "meltdown_warning", "pain_spike"
        ]
      }
    },
    "sleep_rating": { "type": ["integer", "null"], "minimum": 1, "maximum": 10 },
    "energy_rating": { "type": ["integer", "null"], "minimum": 1, "maximum": 10 },
    "stress_rating": { "type": ["integer", "null"], "minimum": 1, "maximum": 10 },
    "context_tags": { "type": "array", "items": { "type": "string" } },
    "summary_text": { "type": "string", "maxLength": 280 },
    "photo_path": { "type": ["string", "null"] },
    "photo_hash": { "type": ["string", "null"] },
    "training_ok": { "type": "boolean", "default": false },
    "private_locked": { "type": "boolean", "default": true },
    "assistant_transcript": { "type": "object" },
    "calibration_snapshot_id": { "type": "string" }
  },
  "additionalProperties": false
}
